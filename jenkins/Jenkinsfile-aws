pipeline {
  agent any

  environment {
    // ECR configuration
    ECR_ACCOUNT_ID  = "254652353999"
    ECR_REGION      = "eu-north-1"
    ECR_REGISTRY    = "${ECR_ACCOUNT_ID}.dkr.ecr.${ECR_REGION}.amazonaws.com"
    IMAGE_NAME      = "portfolio-website"
    IMAGE_TAG       = "${BUILD_NUMBER}"

    // EKS and ArgoCD configuration
    EKS_CLUSTER    = "eks-prod-dr"
    K8S_NAMESPACE  = "portfolio"
    ARGOCD_APP     = "portfolio-aws"
    ARGOCD_NS      = "argocd"

    // AWS credentials from Jenkins credential store
    AWS_ACCESS_KEY_ID     = credentials('aws-access-key-id')
    AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
    AWS_DEFAULT_REGION    = "${ECR_REGION}"

    // GitHub credentials for git push
    GIT_CREDENTIALS = credentials('github-credentials')
    GIT_REPO        = "github.com/yourusername/devops-multicloud-project.git"
  }

  options {
    // Keep only last 10 builds to save disk space
    buildDiscarder(logRotator(numToKeepStr: '10'))
    // Fail if pipeline runs longer than 30 minutes
    timeout(time: 30, unit: 'MINUTES')
    // Never run two builds of same branch simultaneously
    disableConcurrentBuilds()
    // Add timestamps to every console line
    timestamps()
  }

  triggers {
    // Trigger on every GitHub push
    githubPush()
  }

  stages {

    stage('Checkout') {
      steps {
        echo "Checking out code from GitHub"
        echo "Branch:  ${env.GIT_BRANCH}"
        echo "Commit:  ${env.GIT_COMMIT}"
        checkout scm
      }
    }

    stage('Install Dependencies') {
      steps {
        echo "Installing Node.js dependencies"
        dir('website') {
          sh '''
            echo "Node: $(node --version)"
            echo "NPM:  $(npm --version)"
            npm ci
          '''
        }
      }
    }

    stage('Run Tests') {
      steps {
        echo "Running tests"
        dir('website') {
          sh 'npm test'
        }
      }
      post {
        failure {
          echo "Tests failed — pipeline stopped. No broken code deployed."
        }
      }
    }

    stage('Build Docker Image') {
      steps {
        echo "Building Docker image"
        echo "Image: ${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
          sh """
            docker build \
              --no-cache \
              --label build-number=${IMAGE_TAG} \
              --label git-commit=${GIT_COMMIT} \
              -t ${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} \
              -t ${ECR_REGISTRY}/${IMAGE_NAME}:latest \
              .

            echo "Built images:"
            docker images | grep ${IMAGE_NAME}
          """
      }
    }

    stage('Security Scan') {
      steps {
        echo "Scanning image for vulnerabilities"
        sh """

          # Run trivy scan
          trivy image \
            --exit-code 0 \
            --severity HIGH,CRITICAL \
            --no-progress \
            ${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
        """
      }
    }

    stage('Push to ECR') {
      steps {
        echo "Pushing image to ECR"
        sh """
          # Login to ECR
          aws ecr get-login-password \
            --region ${ECR_REGION} \
          | docker login \
            --username AWS \
            --password-stdin \
            ${ECR_REGISTRY}

          # Push versioned tag
          docker push ${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}

          # Push latest tag — always points to newest image
          docker push ${ECR_REGISTRY}/${IMAGE_NAME}:latest

          echo "Pushed successfully:"
          echo "  ${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
          echo "  ${ECR_REGISTRY}/${IMAGE_NAME}:latest"
        """
      }
    }

    // Instead it updates the Git manifest and ArgoCD does the deployment
    stage('Update Git Manifest') {
      steps {
        echo "Updating kustomization.yaml with new image tag"
        sh """
          # Show current tag before change
          echo "Before:"
          grep newTag kubernetes/overlays/aws/kustomization.yaml

          # Update the image tag to this build number
          sed -i \
            's|newTag:.*|newTag: "${IMAGE_TAG}"|g' \
            kubernetes/overlays/aws/kustomization.yaml

          # Show updated tag after change
          echo "After:"
          grep newTag kubernetes/overlays/aws/kustomization.yaml
        """
      }
    }

    stage('Commit and Push Manifest') {
      steps {
        echo "Committing updated manifest to GitHub"
        sh """
          # Configure git identity for this commit
          git config user.email "jenkins@pipeline.com"
          git config user.name "Jenkins CI"

          # Stage only the kustomization file
          git add kubernetes/overlays/aws/kustomization.yaml

          # Check if there are changes to commit
          # If the tag did not change (same build number) skip the commit
          if git diff --staged --quiet; then
            echo "No changes to commit — skipping"
          else
            # Commit with [skip ci] to prevent infinite pipeline loop
            git commit -m "CI: update AWS image tag to ${IMAGE_TAG} [skip ci]"

            # Push using stored GitHub credentials
            git push \
              https://${GIT_CREDENTIALS_USR}:${GIT_CREDENTIALS_PSW}@${GIT_REPO} \
              HEAD:main

            echo "Manifest pushed to GitHub"
            echo "ArgoCD will detect this change and sync automatically"
          fi
        """
      }
    }

   
    stage('Wait for ArgoCD Sync') {
      steps {
        echo "Waiting for ArgoCD to sync and deploy"
        sh """
          # Connect kubectl to EKS so we can check ArgoCD status
          aws eks update-kubeconfig \
            --region ${ECR_REGION} \
            --name ${EKS_CLUSTER}

          echo "Waiting for ArgoCD to detect Git change and sync..."
          echo "This usually takes 30-90 seconds"

          # Poll ArgoCD every 10 seconds for up to 10 minutes
          for i in \$(seq 1 60); do

            SYNC_STATUS=\$(kubectl get application ${ARGOCD_APP} \
              -n ${ARGOCD_NS} \
              -o jsonpath='{.status.sync.status}' 2>/dev/null || echo "Unknown")

            HEALTH_STATUS=\$(kubectl get application ${ARGOCD_APP} \
              -n ${ARGOCD_NS} \
              -o jsonpath='{.status.health.status}' 2>/dev/null || echo "Unknown")

            echo "Attempt \$i/60 — Sync: \$SYNC_STATUS | Health: \$HEALTH_STATUS"

            # Success condition: Synced AND Healthy
            if [ "\$SYNC_STATUS" = "Synced" ] && \
               [ "\$HEALTH_STATUS" = "Healthy" ]; then
              echo "ArgoCD sync complete — application is Healthy"
              exit 0
            fi

            # If OutOfSync but progressing that is normal — keep waiting
            # If Degraded something went wrong
            if [ "\$HEALTH_STATUS" = "Degraded" ]; then
              echo "Application health is Degraded — deployment may have failed"
              kubectl describe application ${ARGOCD_APP} -n ${ARGOCD_NS}
              exit 1
            fi

            sleep 10
          done

          # If we reach here ArgoCD did not sync within 10 minutes
          echo "Timeout: ArgoCD did not sync within 10 minutes"
          kubectl describe application ${ARGOCD_APP} -n ${ARGOCD_NS}
          exit 1
        """
      }
    }

    stage('Verify Deployment') {
      steps {
        echo "Verifying deployment"
        sh """
          echo " Pods "
          kubectl get pods \
            --namespace ${K8S_NAMESPACE} \
            --selector app=portfolio

          echo " Deployment "
          kubectl get deployment portfolio-deployment \
            --namespace ${K8S_NAMESPACE}

          echo " Service "
          kubectl get service portfolio-service \
            --namespace ${K8S_NAMESPACE}

          echo " Ingress "
          kubectl get ingress \
            --namespace ${K8S_NAMESPACE}

          echo " Image running "
          kubectl describe deployment portfolio-deployment \
            --namespace ${K8S_NAMESPACE} \
            | grep Image:
        """
      }
    }

    stage('Health Check') {
      steps {
        echo "Health check on deployed app"
        sh """
          # Port-forward in background
          kubectl port-forward \
            deployment/portfolio-deployment \
            3000:3000 \
            --namespace ${K8S_NAMESPACE} &
          PF_PID=\$!

          # Wait for port-forward to be ready
          sleep 5

          # Check health endpoint
          RESPONSE=\$(curl -s -o /dev/null -w "%{http_code}" \
            http://localhost:3000/health)

          # Kill port-forward
          kill \$PF_PID 2>/dev/null || true

          # Evaluate response
          if [ "\$RESPONSE" = "200" ]; then
            echo "Health check PASSED — app responding with 200"
          else
            echo "Health check FAILED — response was: \$RESPONSE"
            exit 1
          fi
        """
      }
    }

  }

  post {
    success {
      echo """
        PIPELINE SUCCEEDED 
      """
    }

    failure {
      echo """
        PIPELINE FAILED
      """
    }

    always {
      echo "Cleaning up Docker images to free disk space"
      sh """
        docker rmi \
          ${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} \
          2>/dev/null || true

        docker rmi \
          ${ECR_REGISTRY}/${IMAGE_NAME}:latest \
          2>/dev/null || true

        docker image prune -f 2>/dev/null || true

        echo "Cleanup complete"
      """
    }
  }
}